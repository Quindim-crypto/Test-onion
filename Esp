local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

local Enabled = true
local Highlights = {} -- [Player] = Highlight

local TEAM_COLORS = {
	-- usa TeamColor.Name como chave (ex.: "Bright red"), ou ajusta como quiseres
	["Bright red"] = Color3.fromRGB(255, 0, 0),
	["Bright blue"] = Color3.fromRGB(0, 120, 255),
	["Bright green"] = Color3.fromRGB(0, 255, 0),
}
local DEFAULT_COLOR = Color3.fromRGB(255, 0, 0)

local function getPlayerColor(p)
	local tc = p.TeamColor and p.TeamColor.Name
	return (tc and TEAM_COLORS[tc]) or DEFAULT_COLOR
end

local function ensureHighlight(p)
	if p == LocalPlayer then return end
	if Highlights[p] and Highlights[p].Parent then return end

	local h = Instance.new("Highlight")
	h.Name = "DebugESP"
	h.Enabled = Enabled
	h.FillTransparency = 0.6
	h.OutlineTransparency = 0.0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- vê através de paredes (debug)
	Highlights[p] = h

	local function attach()
		if p.Character then
			h.Adornee = p.Character
			h.FillColor = getPlayerColor(p)
			h.OutlineColor = Color3.new(0,0,0)
			h.Parent = p.Character
		end
	end

	p.CharacterAdded:Connect(function()
		attach()
	end)

	attach()
end

local function removeHighlight(p)
	local h = Highlights[p]
	if h then
		h:Destroy()
		Highlights[p] = nil
	end
end

-- Inicializar
for _, p in ipairs(Players:GetPlayers()) do
	ensureHighlight(p)
end

Players.PlayerAdded:Connect(ensureHighlight)
Players.PlayerRemoving:Connect(removeHighlight)

-- Toggle com G
UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.G then
		Enabled = not Enabled
		for _, h in pairs(Highlights) do
			if h then h.Enabled = Enabled end
		end
	end
end)
